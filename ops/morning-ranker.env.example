# Host-side env file for scripts/macmini/morning-ranker.sh
# Copy to ops/morning-ranker.env and fill in values.

# Postgres connection (host can reach Docker Desktop forwarded port 5432)
DATABASE_URL=postgresql://cornintel:cornintel_dev_password@127.0.0.1:5432/cornintel

# Local app/API URL served by nginx on the Mac mini (LAN hostname or loopback)
CORN_INTEL_API_BASE_URL=http://127.0.0.1

# Optional scraper source registry (create from python/bid_sources.example.json)
CORN_INTEL_BID_SOURCE_CONFIG=/Users/cornelius/Documents/Corn Intel/python/bid_sources.json

# Optional ML coefficient file exported by python/train_rank_model.py
# CORN_INTEL_MODEL_COEFFICIENTS_FILE=/Users/cornelius/Documents/Corn Intel/python/model_coefficients.json

# Morning run defaults
CORN_INTEL_MORNING_CROP=Yellow Corn
CORN_INTEL_MORNING_LIMIT=250
CORN_INTEL_MORNING_TOP_N=30
CORN_INTEL_MORNING_TOP_STATES=3
CORN_INTEL_MAX_BID_AGE_HOURS=36
CORN_INTEL_VERIFIED_ONLY=1
