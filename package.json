{
  "name": "crop-intel-usa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src scripts apps/api/src packages/connectors/src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "typecheck:api": "npm --prefix apps/api run typecheck",
    "build:api": "npm --prefix apps/api run build",
    "verify:release": "npm run test && npm run build && npm run typecheck:api && npm run build:api",
    "preview": "vite preview",
    "test:production": "npx tsx scripts/test-production.ts",
    "test:bnsf": "npx tsx scripts/bnsf_carload_rates_smoke.ts",
    "seed:extract-facilities": "npx tsx scripts/extract-facility-seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mendable/firecrawl-js": "^4.15.0",
    "clsx": "^2.1.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "mapbox-gl": "^3.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.5.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mapbox-gl": "^3.1.0",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^28.1.0",
    "osmtogeojson": "^3.0.0-beta.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
